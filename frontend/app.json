{
  "expo": {
    "name": "PLOS",
    "slug": "plos-personal-life-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "supportEmail": "plos.support@gmail.com",
      "privacyPolicyUrl": "https://mosesther130-code.github.io/plos-personal-life-os/privacy-policy.html",
      "termsOfServiceUrl": "https://mosesther130-code.github.io/plos-personal-life-os/terms-of-service.html",
      "developerName": "Moses Ndifon",
      "developerCompany": "LifeOS AI"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Show your location on the safety map and share with family.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Share your location with family when the family location toggle is on.",
        "NSCameraUsageDescription": "Scan documents and add photos to records.",
        "NSPhotoLibraryUsageDescription": "Attach photos to receipts and medical docs.",
        "NSFaceIDUsageDescription": "Unlock PLOS with Face ID."
      },
      "bundleIdentifier": "com.mosesndifon.plos"
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ],
      "package": "com.mosesndifon.plos"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
